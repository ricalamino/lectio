{
  "name": "@lectio/core",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "default": "./dist/db/index.js"
    },
    "./db/schema": {
      "types": "./dist/db/schema.d.ts",
      "default": "./dist/db/schema.js"
    },
    "./llm": {
      "types": "./dist/llm/index.d.ts",
      "default": "./dist/llm/index.js"
    },
    "./prompts": {
      "types": "./dist/prompts/index.d.ts",
      "default": "./dist/prompts/index.js"
    },
    "./integrations/openai-media": {
      "types": "./dist/integrations/openaiMedia.d.ts",
      "default": "./dist/integrations/openaiMedia.js"
    },
    "./integrations/transcribe": {
      "types": "./dist/integrations/transcribe.d.ts",
      "default": "./dist/integrations/transcribe.js"
    },
    "./integrations/pdf": {
      "types": "./dist/integrations/pdf.d.ts",
      "default": "./dist/integrations/pdf.js"
    },
    "./integrations/video": {
      "types": "./dist/integrations/video.d.ts",
      "default": "./dist/integrations/video.js"
    },
    "./importers": {
      "types": "./dist/importers/index.d.ts",
      "default": "./dist/importers/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/copy-migrations.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "echo 'no lint configured'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.32.1",
    "openai": "4.68.4",
    "drizzle-orm": "0.36.0",
    "pdf-parse": "1.1.1",
    "postgres": "3.4.5",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "drizzle-kit": "0.28.0",
    "tsx": "4.19.1",
    "typescript": "5.6.2",
    "vitest": "2.1.2",
    "@types/node": "20.16.10"
  }
}
