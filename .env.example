# Required
DATABASE_URL=postgresql://lectio:changeme@localhost:5432/lectio
POSTGRES_PASSWORD=changeme-use-openssl-rand-base64-32
MINIO_ROOT_PASSWORD=changeme-use-openssl-rand-base64-32
AUTH_SECRET=changeme-use-openssl-rand-base64-32
ADMIN_PASSWORD=pick-a-strong-password

# At least one of these required
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Worker model selection (defaults are sane; override if you want)
LECTIO_ENRICH_PROVIDER=anthropic
LECTIO_ENRICH_MODEL=claude-sonnet-4-6
LECTIO_SEARCH_PROVIDER=anthropic
LECTIO_SEARCH_MODEL=claude-sonnet-4-6
LECTIO_EMBED_PROVIDER=openai
LECTIO_EMBED_MODEL=text-embedding-3-small
# IMPORTANT: LECTIO_EMBED_DIMENSIONS must match the DB vector column dimension.
# Default is 1536 (OpenAI text-embedding-3-small / text-embedding-ada-002).
# If you switch models, drop and recreate the embedding column first, then set
# this value to the new dimension before starting the worker.
# Fully local alternative (768 dimensions):
#   LECTIO_EMBED_PROVIDER=ollama
#   LECTIO_EMBED_MODEL=nomic-embed-text
#   LECTIO_EMBED_DIMENSIONS=768
LECTIO_EMBED_DIMENSIONS=1536
# Transcription (voice notes + video audio). Default is OpenAI Whisper when
# OPENAI_API_KEY is set. To run a local Whisper server, set:
#   LECTIO_TRANSCRIBE_BACKEND=openai_compatible
#   LECTIO_TRANSCRIBE_URL=http://faster-whisper:9000/v1   # any OpenAI-compatible
#   LECTIO_WHISPER_MODEL=Systran/faster-whisper-base       # backend-specific
# LECTIO_TRANSCRIBE_API_KEY=...  # only when the local server requires auth
LECTIO_WHISPER_MODEL=whisper-1
# Image OCR (vision). OpenAI-only for now.
LECTIO_VISION_MODEL=gpt-4o-mini

# Optional
LECTIO_PORT=3000
